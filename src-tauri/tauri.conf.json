{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "protoforge",
  "version": "0.3.8",
  "identifier": "com.protoforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProtoForge - API Development Tool",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https: http:; connect-src 'self' ws://127.0.0.1:* wss://127.0.0.1:* ws://localhost:* http://127.0.0.1:* https: http: data: blob:; media-src 'self' blob: data: http://127.0.0.1:* https: asset: http://asset.localhost; img-src 'self' data: blob: https: http: asset: http://asset.localhost; font-src 'self' data: asset: http://asset.localhost https://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/chenqi92/protoforge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDMDgzRkY4QzFDMEFEMzIKUldReXJjREIrRDhJYlBYdTVGT1orbVYvUDE4NHdpb2U2UjJ6MWpNRnAzT3hYdHNLUGU3MFFDYncK"
    }
  }
}
