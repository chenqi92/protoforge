    "i18next": "^25.8.20",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.8",
    "react-resizable-panels": "^4.7.3",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
